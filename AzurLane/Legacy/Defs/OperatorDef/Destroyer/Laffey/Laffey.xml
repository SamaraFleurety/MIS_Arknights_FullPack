				<label>所罗门的战神</label>
				<description>状态良好……去吧</description>
				<statOffsets>
					<AimingDelayFactor>-0.35</AimingDelayFactor>
					<ShootingAccuracyPawn>2.0</ShootingAccuracyPawn>
				</statOffsets>
				<skillGains>
					<Shooting>4</Shooting>
				</skillGains>
			</li>
		</degreeDatas>
	</TraitDef>
	<ThoughtDef>
		<defName>LMA_Thought_Trait_Laffey</defName>
