	<HairDef ParentName="LMA_HairBase">
		<defName>LMA_Hair_Laffey</defName>
		<label>拉菲发型</label>
		<texPath>Things/Hair/Destroyer/Laffey</texPath>
		<noGraphic>true</noGraphic>
		<modExtensions>
			<li Class="AK_DLL.Ext_FrontHair">
				<graphicData>
					<texPath>Things/Hair/Destroyer/Laffey</texPath>
					<graphicClass>Graphic_Multi</graphicClass>
					<drawSize>1.3</drawSize>
					<drawOffsetSouth>(0,0,-0.05)</drawOffsetSouth>
					<drawOffsetNorth>(0,0,-0.05)</drawOffsetNorth>
					<drawOffsetEast>(-0.08,0,-0.05)</drawOffsetEast>
					<drawOffsetWest>(0.08,0,-0.05)</drawOffsetWest>
				</graphicData>
				<sleepingDrawOffsets>
					<!-- 如果下面4项某项删掉就应用第一个通用数值。这里仅做展示，实际不要5个词条全写这样留冗余 -->
					<drawOffset>(1,0,1)</drawOffset>
					<drawOffsetSouth>(1,0,1)</drawOffsetSouth>
					<drawOffsetNorth>(1,0,1)</drawOffsetNorth>
					<drawOffsetEast>(1,0,1)</drawOffsetEast>
					<drawOffsetWest>(1,0,1)</drawOffsetWest>
				</sleepingDrawOffsets>
			</li>
			<li Class="AK_DLL.Ext_BackHair">
				<graphicData>
					<texPath>Things/Hair/Destroyer/LaffeyA</texPath>
					<graphicClass>Graphic_Multi</graphicClass>
					<drawSize>1.3</drawSize>
					<drawOffsetSouth>(0,-0.5,-0.05)</drawOffsetSouth>
					<drawOffsetNorth>(0,0,-0.05)</drawOffsetNorth>
					<drawOffsetEast>(-0.08,0,-0.05)</drawOffsetEast>
					<drawOffsetWest>(0.08,0,-0.05)</drawOffsetWest>
				</graphicData>
			</li>
		</modExtensions>
	</HairDef>

